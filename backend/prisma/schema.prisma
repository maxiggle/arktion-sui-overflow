generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  walletAddress String    @unique @map("wallet_address")
  email         String?   @unique
  displayName   String?   @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  oauthIss        String    @map("oauth_iss")
  oauthSub        String    @map("oauth_sub")
  zkLoginSalt   String    @map("zklogin_salt")
  libraryObjectId String?   @map("library_object_id")
  journalObjectId String?   @map("journal_object_id")
  bootstrapState     String?   @map("bootstrap_state")
  bootstrapStartedAt DateTime? @map("bootstrap_started_at")
  bootstrapTxDigest  String?   @map("bootstrap_tx_digest")
  creatorStatus CreatorStatus @default(NONE) @map("creator_status")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  passport          Passport?
  readingRecords    ReadingRecord[]
  journalEntries    JournalEntry[]
  submissions       Submission[]
  inkLedger         InkLedgerEntry[]
  inkBalance        InkBalance?
  badgesEarned      BadgeEarned[]
  sessions          Session[]
  earningRecords    EarningRecord[]
  createdSeries     Series[]         @relation("CreatorSeries")
  tipsSent          TipTransaction[] @relation("TipSender")
  tipsReceived      TipTransaction[] @relation("TipReceiver")
  usdcBalance       UserUsdcBalance?
  creatorApplication CreatorApplication?

  @@unique([oauthIss, oauthSub])
  @@index([walletAddress])
  @@index([email])
  @@map("users")
}

model Session {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  expiresAt     DateTime  @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  userAgent     String?   @map("user_agent") @db.Text
  ipAddress     String?   @map("ip_address")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastUsedAt    DateTime  @default(now()) @map("last_used_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Passport {
  id              String   @id @default(uuid())
  userId          String   @unique @map("user_id")
  suiObjectId     String   @unique @map("sui_object_id")
  level           Int      @default(1)
  totalInkEarned  BigInt   @default(0) @map("total_ink_earned")
  chaptersRead    Int      @default(0) @map("chapters_read")
  seriesCompleted Int      @default(0) @map("series_completed")
  seriesTracked   Int      @default(0) @map("series_tracked")
  identityBlobId  String?  @map("identity_blob_id")
  lastSyncedAt    DateTime @default(now()) @map("last_synced_at")

  user            User     @relation(fields: [userId], references: [id])

  @@index([suiObjectId])
  @@map("passports")
}

model Series {
  id              String    @id @default(uuid())
  externalId      String    @unique @map("external_id")
  title           String
  formatType      Int       @map("format_type")
  sourceLanguage  String    @map("source_language")
  coverUrl        String?   @map("cover_url")
  coverBlobId     String?   @map("cover_blob_id")
  description     String?   @db.Text
  status          String    @default("ongoing")
  metadataBlobId  String?   @map("metadata_blob_id")
  /// Last time the chapter list was synced from the external source (MangaDex).
  chaptersSyncedAt DateTime? @map("chapters_synced_at")
  /// Platform creator who owns this series and receives USDC tips.
  /// Null for externally sourced series that have no registered creator on Arktion.
  creatorId       String?   @map("creator_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  creator         User?           @relation("CreatorSeries", fields: [creatorId], references: [id])
  readingRecords  ReadingRecord[]
  badgesEarned    BadgeEarned[]
  chapters        Chapter[]
  tipTransactions TipTransaction[]

  @@index([externalId])
  @@index([title])
  @@index([creatorId])
  @@map("series")
}

model Chapter {
  id            String    @id @default(uuid())
  seriesId      String    @map("series_id")
  /// External chapter id from the upstream source (MangaDex chapter UUID for Phase 1).
  /// Null when the chapter was uploaded directly via Comic Studio (Phase 2).
  externalId    String?   @unique @map("external_id")
  /// Decimal so half-chapters like 1.5 work for manga side stories.
  chapterNumber Float     @map("chapter_number")
  title         String?
  /// Translation language. ISO 639-1 (e.g. "en", "ja").
  language      String    @default("en")
  pageCount     Int       @default(0) @map("page_count")
  /// Phase 2 paid-chapter gate. Phase 1 chapters are always free.
  isLicensed    Boolean   @default(false) @map("is_licensed")
  inkCost       Int       @default(0) @map("ink_cost")
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  series        Series    @relation(fields: [seriesId], references: [id])
  pages         Page[]

  @@unique([seriesId, language, chapterNumber])
  @@index([seriesId, language])
  @@index([externalId])
  @@map("chapters")
}

model Page {
  id         String   @id @default(uuid())
  chapterId  String   @map("chapter_id")
  pageNumber Int      @map("page_number")
  imageUrl   String   @map("image_url") @db.Text
  width      Int?
  height     Int?
  createdAt  DateTime @default(now()) @map("created_at")

  chapter    Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([chapterId, pageNumber])
  @@index([chapterId])
  @@map("pages")
}

model ReadingRecord {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  seriesId        String    @map("series_id")
  status          Int       @default(0)
  currentChapter  Int       @default(0) @map("current_chapter")
  lastReadAt      DateTime  @default(now()) @map("last_read_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User      @relation(fields: [userId], references: [id])
  series          Series    @relation(fields: [seriesId], references: [id])

  @@unique([userId, seriesId])
  @@index([userId, status])
  @@index([seriesId])
  @@map("reading_records")
}

model JournalEntry {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  entryId               String   @map("entry_id")
  externalTitle         String   @map("external_title")
  formatType            Int      @map("format_type")
  externalUrl           String   @map("external_url")
  totalChapters         Int      @default(0) @map("total_chapters")
  currentChapter        Int      @default(0) @map("current_chapter")
  notes                 String?  @db.Text
  submittedAsSuggestion Boolean  @default(false) @map("submitted_as_suggestion")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user                  User     @relation(fields: [userId], references: [id])

  @@unique([userId, entryId])
  @@index([userId])
  @@map("journal_entries")
}

model Submission {
  id              String    @id @default(uuid())
  submitterId     String    @map("submitter_id")
  suiObjectId     String    @unique @map("sui_object_id")
  title           String
  formatType      Int       @map("format_type")
  externalUrl     String    @map("external_url")
  suggestedSource String    @map("suggested_source")
  status          Int       @default(0)
  reviewedAt      DateTime? @map("reviewed_at")
  rewardClaimed   Boolean   @default(false) @map("reward_claimed")
  createdAt       DateTime  @default(now()) @map("created_at")

  submitter       User      @relation(fields: [submitterId], references: [id])

  @@index([submitterId])
  @@index([status])
  @@index([suiObjectId])
  @@map("submissions")
}

model InkLedgerEntry {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  actionType     Int      @map("action_type")
  amount         BigInt
  idempotencyKey String   @unique @map("idempotency_key")
  suiTxDigest    String?  @map("sui_tx_digest")
  createdAt      DateTime @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([idempotencyKey])
  @@map("ink_ledger_entries")
}

model InkBalance {
  userId        String   @id @map("user_id")
  balance       BigInt   @default(0)
  lastUpdatedAt DateTime @default(now()) @map("last_updated_at")

  user          User     @relation(fields: [userId], references: [id])

  @@map("ink_balances")
}

model EarningRecord {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  suiObjectId    String   @unique @map("sui_object_id")
  idempotencyKey String   @unique @map("idempotency_key")
  triggerType    Int      @map("trigger_type")
  amount         BigInt
  earnedAt       DateTime @default(now()) @map("earned_at")

  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("earning_records")
}

model BadgeEarned {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  suiObjectId    String   @unique @map("sui_object_id")
  category       Int
  badgeType      Int      @map("badge_type")
  seriesId       String?  @map("series_id")
  tier           Int      @default(0)
  metadataBlobId String   @map("metadata_blob_id")
  awardedAt      DateTime @default(now()) @map("awarded_at")

  user           User     @relation(fields: [userId], references: [id])
  series         Series?  @relation(fields: [seriesId], references: [id])

  @@unique([userId, category, badgeType, seriesId])
  @@index([userId])
  @@map("badges_earned")
}

model IdempotencyKey {
  key        String   @id
  scope      String
  userId     String?  @map("user_id")
  resourceId String?  @map("resource_id")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([scope])
  @@map("idempotency_keys")
}

/// USDC tip from a reader to a series creator.
/// Amounts are in micro-USDC (6 decimal places). 1 USDC = 1_000_000.
/// status: 0 = pending (bytes sent to frontend), 1 = confirmed on-chain, 2 = failed.
model TipTransaction {
  id             String   @id @default(uuid())
  senderId       String   @map("sender_id")
  receiverId     String   @map("receiver_id")
  seriesId       String   @map("series_id")
  /// Amount in micro-USDC (6 decimal places).
  amountUsdc     BigInt   @map("amount_usdc")
  suiTxDigest    String?  @unique @map("sui_tx_digest")
  status         Int      @default(0)
  idempotencyKey String   @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")
  confirmedAt    DateTime? @map("confirmed_at")

  sender         User     @relation("TipSender", fields: [senderId], references: [id])
  receiver       User     @relation("TipReceiver", fields: [receiverId], references: [id])
  series         Series   @relation(fields: [seriesId], references: [id])

  @@index([senderId])
  @@index([receiverId])
  @@index([seriesId])
  @@index([status])
  @@map("tip_transactions")
}

/// Postgres mirror of a user's USDC coin balance on Sui.
/// Updated after each confirmed tip send or receive.
/// For fresh on-chain data query the user's USDC coin objects directly.
model UserUsdcBalance {
  userId        String   @id @map("user_id")
  /// Balance in micro-USDC (6 decimal places).
  balance       BigInt   @default(0)
  lastSyncedAt  DateTime @default(now()) @map("last_synced_at")

  user          User     @relation(fields: [userId], references: [id])

  @@map("user_usdc_balances")
}

enum CreatorStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

model CreatorApplication {
  userId       String   @id @map("user_id")
  /// 3–5 sentence pitch for their first series.
  pitch        String   @db.Text
  /// Planned release cadence: weekly | bi-weekly | monthly | one-shot
  cadence      String
  /// Tools they create with (Clip Studio, Procreate, Google Docs, etc.)
  tooling      String
  /// Optional link to existing portfolio / published work.
  portfolioUrl String?  @map("portfolio_url")
  submittedAt  DateTime @default(now()) @map("submitted_at")
  reviewedAt   DateTime? @map("reviewed_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("creator_applications")
}

enum AdminRole {
  SUPER_ADMIN
  MODERATOR
  REVIEWER
}

model AdminUser {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String    @map("password_hash")
  role                AdminRole @default(REVIEWER)
  isActive            Boolean   @default(true) @map("is_active")

  /// AES-256-GCM encrypted TOTP secret (iv:authTag:ciphertext, hex-encoded)
  totpSecret          String?   @map("totp_secret")
  totpEnabled         Boolean   @default(false) @map("totp_enabled")
  /// bcrypt-hashed single-use backup codes
  totpBackupCodes     String[]  @map("totp_backup_codes")

  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  lastLoginAt         DateTime? @map("last_login_at")
  lastLoginIp         String?   @map("last_login_ip")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  sessions            AdminSession[]
  actionLogs          AdminActionLog[]

  @@index([email])
  @@map("admin_users")
}

model AdminSession {
  id               String    @id @default(uuid())
  adminId          String    @map("admin_id")
  /// SHA-256(refresh_token) — used for refresh token verification & revocation
  refreshTokenHash String    @map("refresh_token_hash")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent") @db.Text
  /// Expiry of the refresh token (7 days). Access tokens self-expire via JWT exp.
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  lastUsedAt       DateTime  @default(now()) @map("last_used_at")

  admin            AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([refreshTokenHash])
  @@map("admin_sessions")
}

model AdminActionLog {
  id          String     @id @default(uuid())
  adminId     String?    @map("admin_id")
  actionType  String     @map("action_type")
  targetId    String?    @map("target_id")
  targetType  String?    @map("target_type")
  metadata    Json?
  ipAddress   String?    @map("ip_address")
  createdAt   DateTime   @default(now()) @map("created_at")

  admin       AdminUser? @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([actionType])
  @@index([createdAt])
  @@map("admin_action_logs")
}
