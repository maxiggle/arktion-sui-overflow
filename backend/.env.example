# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a Postgres service
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-min-32-chars
JWT_EXPIRES_IN=7d

# Google OAuth client ID (from Google Cloud Console — same one used in zkLogin)
GOOGLE_CLIENT_ID=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production.
# Set to your Railway frontend URL:
# CORS_ORIGIN=https://arktion-frontend.up.railway.app,https://arktion.io
CORS_ORIGIN=https://arktion.io

# ── Sui ───────────────────────────────────────────────────────────────────────
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_PACKAGE_ID=0x18fdcc9d94ca3644c768730de7e4d4731e0af7f230e3c4dfa792e6e28577ed90
SUI_ADMIN_REGISTRY_ID=0xa06eb469b1bb8187ddea83385d586c542f81ce0c573615aed202bb9a9be6463c
SUI_EARNING_REGISTRY_ID=0x017fde8088596c458b9a28aea2a6e5457e18d67134337f9639d0268f70f1f2f3
SUI_ADMIN_CAP_ID=0x32662928487849bab8d3a17fdf554f72d414017b90dbac86f4aefa286b1f9a2d
SUI_INK_TREASURY_CAP_ID=0xd5b181791ff8316c862a5184ce14378d41b4303eb84a5ebcc815e2a115357f5d
SUI_BADGE_REGISTRY_ID=
SUI_USDC_COIN_TYPE=

# Bech32 Ed25519 private keys (suiprivkey1...)
ADMIN_SECRET_KEY=
GAS_SPONSOR_SECRET_KEY=
GAS_TREASURY_MIN_BALANCE=10000000000

# ── zkLogin ───────────────────────────────────────────────────────────────────
ZKLOGIN_PROVER_URL=https://prover-dev.mystenlabs.com/v1

# ── Walrus ────────────────────────────────────────────────────────────────────
WALRUS_UPLOAD_RELAY_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_DEFAULT_EPOCHS=5

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=change-me-min-32-chars-separate-from-jwt-secret
TOTP_ISSUER=Arktion Admin
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=
