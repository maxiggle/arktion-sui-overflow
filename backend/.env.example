# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a Postgres service
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-min-32-chars
JWT_EXPIRES_IN=7d

# Google OAuth client ID (from Google Cloud Console — same one used in zkLogin)
GOOGLE_CLIENT_ID=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins in production.
# Set to your Railway frontend URL:
# CORS_ORIGIN=https://arktion-frontend.up.railway.app,https://arktion.io
CORS_ORIGIN=https://arktion.io

# ── Sui ───────────────────────────────────────────────────────────────────────
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_PACKAGE_ID=0xb35f71ecf5e474a426a5a70a451e582ef92c72cbcad660e071ea74dd008e5b5f
SUI_ADMIN_REGISTRY_ID=0x5e4dce4d703d64b9aa2ebb6a94cfc04a5ebce922e59c0c206e47ec997c95d128
SUI_EARNING_REGISTRY_ID=0x3d585639de76c4f458d5e210882b1b829bebbf753255c767e295c85165d9fe68
SUI_ADMIN_CAP_ID=0xd335ddae39ccafc92cc30b20861a3e0f3c105da311bc1e0f3649624e7707ae0c
SUI_INK_TREASURY_CAP_ID=0x34a1e9bb1174a298eb41108edeb6532858e8266bec0e45e5a7ca7ef508bb8f80
SUI_BADGE_REGISTRY_ID=0xca81b042295dd5faa59eb68d492ff0a57a4e0a3e89c5385bdf25f4defb870694
SUI_USDC_COIN_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC
# Shared PassportConfig object (holds the admin Ed25519 pubkey for attested passport syncs)
SUI_PASSPORT_CONFIG_ID=0x23eba300571024bc932ebe14a3b5a42e26ba5749c2f1edec4d4a979977877ef8

# Bech32 Ed25519 private keys (suiprivkey1...)
ADMIN_SECRET_KEY=
GAS_SPONSOR_SECRET_KEY=
GAS_TREASURY_MIN_BALANCE=10000000000

# ── zkLogin ───────────────────────────────────────────────────────────────────
ZKLOGIN_PROVER_URL=https://prover-dev.mystenlabs.com/v1

# ── Walrus ────────────────────────────────────────────────────────────────────
WALRUS_UPLOAD_RELAY_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_DEFAULT_EPOCHS=5

# ── AI Writing Assistant ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=
# Any OpenRouter model slug. Free options: google/gemma-3-27b-it:free
OPENROUTER_MODEL=google/gemma-3-27b-it:free
MEMWAL_ACCOUNT_ID=
MEMWAL_PRIVATE_KEY=
MEMWAL_SERVER_URL=https://relayer-staging.memory.walrus.xyz

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=change-me-min-32-chars-separate-from-jwt-secret
TOTP_ISSUER=Arktion Admin
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=
